{
    "domains": [
        {
            "name": "自定义订阅源",
            "sub": [
                "如果你有自带的机场订阅链接，请填在这里，保留双引号"
            ],
            "enable": true,
            "include": "(?i)HK|Hong Kong|香港|SG|Singapore|新加坡",
            "exclude": "(下载|游戏|官网|剩余|到期)专用",
            "push_to": [
                "au_group"
            ]
        }
    ],
    "crawl": {
        "enable": true,
        "singlelink": true,
        "github": {
            "enable": true,
            "pages": 2,
            "push_to": [
                "au_group"
            ]
        },
        "telegram": {
            "enable": true,
            "pages": 5,
            "users": {
                "V2List": {
                    "push_to": ["au_group"]
                }
            }
        }
    },
    "groups": {
        "au_group": {
            "emoji": true,
            "list": true,
            "targets": {
                "clash": "au-clash",
                "singbox": "au-singbox",
                "v2ray": "au-v2ray"
            },
            "regularize": {
                "locate": true,
                "residential": true
            }
        }
    },
    "storage": {
        "engine": "gist",
        "items": {
            "au-clash": {
                "gistid": "4d55ce6d887f17cee17158e0051dab63",
                "filename": "au-clash.yaml"
            },
            "au-singbox": {
                "gistid": "4d55ce6d887f17cee17158e0051dab63",
                "filename": "au-singbox.json"
            },
            "au-v2ray": {
                "gistid": "4d55ce6d887f17cee17158e0051dab63",
                "filename": "au-v2ray.txt"
            }
        }
    }
}
